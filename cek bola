<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <title>Vault Zero - Stadium Dark v10</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      /* Warna Khusus Sepakbola Dark */
      :root {
        --pitch-dark: #0f172a; /* Biru Dongker Gelap */
        --grass-green: #22c55e; /* Hijau Lapangan */
        --stadium-border: #1e293b;
      }
      body {
        background-color: var(--pitch-dark);
        color: #f1f5f9;
        font-family: "Inter", sans-serif;
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      input[type="number"]::-webkit-inner-spin-button,
      input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
      }

      .win-text {
        color: var(--grass-green);
        font-weight: 800;
        text-shadow: 0 0 10px rgba(34, 197, 94, 0.3);
      }
      .lose-text {
        color: #ef4444;
        font-weight: 800;
        text-shadow: 0 0 10px rgba(239, 68, 68, 0.3);
      }
      .draw-text {
        color: #94a3b8;
        font-weight: 800;
      }

      .custom-scroll::-webkit-scrollbar {
        width: 6px;
      }
      .custom-scroll::-webkit-scrollbar-track {
        background: #0f172a;
      }
      .custom-scroll::-webkit-scrollbar-thumb {
        background: #334155;
        border-radius: 10px;
      }

      /* Animasi saat generate */
      @keyframes glow {
        0% {
          border-color: #1e293b;
        }
        50% {
          border-color: #22c55e;
        }
        100% {
          border-color: #1e293b;
        }
      }
      .active-row {
        animation: glow 2s infinite;
      }
    </style>
  </head>
  <body>
    <header
      class="bg-[#1e293b] border-b border-slate-700 px-8 py-4 flex justify-between items-center shrink-0 shadow-lg"
    >
      <h1
        class="text-xl font-black italic tracking-tighter text-white uppercase"
      >
        Vault Zero <span class="text-green-500 italic">Stadium Dark</span>
      </h1>
      <div class="flex items-center gap-4">
        <span
          class="flex h-2 w-2 rounded-full bg-green-500 animate-pulse"
        ></span>
        <div
          class="text-[10px] font-mono text-slate-400 uppercase tracking-widest"
        >
          Live Engine v10.0
        </div>
      </div>
    </header>

    <main class="flex flex-1 overflow-hidden">
      <section
        class="w-[30%] border-r border-slate-800 bg-[#0f172a] p-6 flex flex-col gap-4"
      >
        <div class="flex-1 flex flex-col">
          <span
            class="text-[10px] font-black text-slate-500 uppercase mb-2 tracking-widest"
            >Parlay Ticket Input</span
          >
          <textarea
            id="rawInput"
            class="flex-1 w-full border border-slate-800 rounded-2xl p-5 text-[11px] font-mono outline-none focus:border-green-500 bg-[#1e293b] text-slate-200 resize-none custom-scroll shadow-inner transition-all"
            placeholder="Tempel bill di sini..."
          ></textarea>
        </div>
        <button
          onclick="processData()"
          class="w-full bg-green-600 text-white py-4 rounded-xl text-xs font-black hover:bg-green-500 shadow-xl shadow-green-900/20 uppercase tracking-widest transition-all"
        >
          Analyze Ticket Now
        </button>
      </section>

      <section class="flex-1 bg-[#020617] p-8 overflow-y-auto custom-scroll">
        <div id="resultArea" class="hidden">
          <div
            class="bg-[#0f172a] rounded-[32px] border border-slate-800 shadow-2xl overflow-hidden mb-6"
          >
            <table class="w-full text-left">
              <thead>
                <tr
                  class="bg-slate-900/50 text-[10px] font-bold text-slate-500 border-b border-slate-800 uppercase tracking-widest"
                >
                  <th class="p-6">Match Details</th>
                  <th class="p-6 text-center">Pick</th>
                  <th class="p-6">Description</th>
                  <th class="p-6 text-center">Score</th>
                  <th class="p-6 text-right">Status</th>
                </tr>
              </thead>
              <tbody
                id="matchList"
                class="text-xs font-semibold text-slate-300"
              ></tbody>
            </table>
          </div>

          <div
            class="bg-[#1e293b] rounded-[32px] p-8 flex justify-between items-center border border-slate-700 shadow-2xl"
          >
            <div>
              <p
                class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1"
              >
                Final Outcome
              </p>
              <h2
                id="finalStatus"
                class="text-3xl font-black italic tracking-tighter uppercase"
              >
                Waiting...
              </h2>
            </div>
            <div class="flex gap-3">
              <button
                onclick="window.print()"
                class="bg-slate-800 hover:bg-slate-700 text-slate-300 px-6 py-3 rounded-2xl text-[10px] font-bold uppercase tracking-widest border border-slate-700 transition-all"
              >
                Export PDF
              </button>
            </div>
          </div>
        </div>

        <div
          id="placeholder"
          class="h-full flex flex-col items-center justify-center text-slate-600 italic text-center"
        >
          <svg
            class="w-16 h-16 mb-4 opacity-10"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"
            />
          </svg>
          <p>
            Silahkan masukkan bill parlay<br />untuk tampilan visual premium
          </p>
        </div>
      </section>
    </main>

    <script>
      function processData() {
        const rawText = document.getElementById("rawInput").value;
        const blocks = rawText
          .split(/Soccer\s+/)
          .filter((b) => b.trim() !== "");
        const list = document.getElementById("matchList");
        if (blocks.length === 0) return;

        list.innerHTML = "";
        document.getElementById("placeholder").classList.add("hidden");
        document.getElementById("resultArea").classList.remove("hidden");

        blocks.forEach((block) => {
          const lines = block
            .split("\n")
            .map((l) => l.trim())
            .filter((l) => l !== "");
          const matchLine =
            lines.find((l) => l.includes(" vs ")) || "Home vs Away";
          const teams = matchLine.split(" vs ");
          const league =
            lines.find((l) => l.toUpperCase() === l && l.includes(" ")) ||
            "Tournament";

          const searchQuery = encodeURIComponent(matchLine + " live score");
          const liveLink = `https://www.google.com/search?q=${searchQuery}`;

          const betLine = lines.find((l) => l.includes("Bet: ")) || "";
          let type = "HDP",
            pick = teams[0],
            betValue = 0;

          if (betLine.toLowerCase().includes("over/under")) {
            type = "OU";
            pick = betLine.includes("over") ? "OVER" : "UNDER";
            betValue = parseFloat(betLine.match(/[\d.]+/));
          } else {
            const side = betLine.toLowerCase().includes("away")
              ? "AWAY"
              : "HOME";
            pick = side === "AWAY" ? teams[1] : teams[0];
            betValue = parseFloat(betLine.match(/[-]*[\d.]+/));
          }

          let ket =
            type === "OU"
              ? `Main <span class="text-green-500">${pick}</span> gol <span class="text-white">${betValue}</span>`
              : betValue < 0
              ? `<span class="text-green-500">${pick}</span> memberi poor <span class="text-white">${Math.abs(
                  betValue
                )}</span>`
              : `<span class="text-green-500">${pick}</span> menerima poor <span class="text-white">${betValue}</span>`;

          const tr = document.createElement("tr");
          tr.className =
            "border-b border-slate-800/50 hover:bg-slate-800/30 transition-all";
          tr.innerHTML = `
                    <td class="p-6">
                        <div class="text-slate-100 font-bold tracking-tight">${
                          teams[0]
                        } vs ${teams[1]}</div>
                        <div class="flex flex-col gap-1 mt-1">
                            <span class="text-[9px] text-slate-500 uppercase tracking-tighter">${league}</span>
                            <a href="${liveLink}" target="_blank" class="text-green-500/80 text-[10px] font-bold hover:text-green-400 flex items-center gap-1 transition-all">
                                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> LIVE SCORE
                            </a>
                        </div>
                    </td>
                    <td class="p-6 text-center">
                        <span class="bg-slate-800 text-green-400 px-3 py-1.5 rounded-lg text-[10px] font-black uppercase border border-slate-700 shadow-sm">${pick}</span>
                    </td>
                    <td class="p-6 text-[11px] text-slate-500 italic font-medium">${ket}</td>
                    <td class="p-6 text-center">
                        <div class="flex items-center justify-center gap-2">
                            <input type="number" placeholder="0" oninput="calculate()" class="h-score w-10 text-center bg-slate-800 border border-slate-700 rounded-lg p-2 outline-none font-bold text-white focus:ring-1 focus:ring-green-500 transition-all">
                            <span class="text-slate-600 font-bold">:</span>
                            <input type="number" placeholder="0" oninput="calculate()" class="a-score w-10 text-center bg-slate-800 border border-slate-700 rounded-lg p-2 outline-none font-bold text-white focus:ring-1 focus:ring-green-500 transition-all">
                        </div>
                    </td>
                    <td class="p-6 text-right status-label italic uppercase text-[10px] font-black tracking-widest text-slate-600">Pending</td>
                    <input type="hidden" class="bet-type" value="${type}">
                    <input type="hidden" class="bet-side" value="${
                      betLine.toLowerCase().includes("away") ? "away" : "home"
                    }">
                    <input type="hidden" class="bet-val" value="${betValue}">
                    <input type="hidden" class="ou-pick" value="${pick}">
                `;
          list.appendChild(tr);
        });
        calculate();
      }

      function calculate() {
        const rows = document.querySelectorAll("#matchList tr");
        let parlayStatus = "WIN";

        rows.forEach((row) => {
          const hVal = row.querySelector(".h-score").value;
          const aVal = row.querySelector(".a-score").value;
          const h = parseInt(hVal) || 0;
          const a = parseInt(aVal) || 0;
          const type = row.querySelector(".bet-type").value;
          const side = row.querySelector(".bet-side").value;
          const bet = parseFloat(row.querySelector(".bet-val").value);
          const ouPick = row.querySelector(".ou-pick").value;
          const label = row.querySelector(".status-label");

          if (hVal === "" && aVal === "") {
            label.innerText = "Pending";
            label.className =
              "p-6 text-right status-label italic uppercase text-[10px] font-black text-slate-600";
            return;
          }

          let res = 0;
          if (type === "OU") {
            res = h + a - bet;
            if (ouPick === "UNDER") res = -res;
          } else {
            const diff = side === "away" ? a - h : h - a;
            res = bet < 0 ? diff - Math.abs(bet) : diff + bet;
          }

          if (res > 0.25) updateLabel(label, "WIN");
          else if (res === 0.25) updateLabel(label, "WIN 1/2");
          else if (res === 0) updateLabel(label, "DRAW");
          else if (res === -0.25) {
            updateLabel(label, "LOSE 1/2");
            parlayStatus = "LOSE 1/2";
          } else {
            updateLabel(label, "LOSE");
            parlayStatus = "LOSE";
          }
        });

        function updateLabel(el, stat) {
          el.innerText = stat;
          el.className = `p-6 text-right status-label italic uppercase text-[10px] font-black ${
            stat.includes("WIN")
              ? "win-text"
              : stat.includes("LOSE")
              ? "lose-text"
              : "draw-text"
          }`;
        }

        const final = document.getElementById("finalStatus");
        final.innerText =
          parlayStatus === "WIN"
            ? "RUNNING / ALL WIN"
            : "TICKET " + parlayStatus;
        final.className = `text-3xl font-black italic tracking-tighter ${
          parlayStatus === "WIN" ? "text-green-500" : "text-red-500"
        }`;
      }
    </script>
  </body>
</html>
