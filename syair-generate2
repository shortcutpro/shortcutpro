  <!-- Pasaran -->
  <div class="locations-card">
    <h3>PASARAN</h3>
    <div class="locations-list" id="locationsList"></div>
  </div>

</div>



<script>
  // ── Tanggal ───────────────────────────────────────────────
  function updateDate() {
    const opts = { weekday:'long', day:'numeric', month:'long', year:'numeric' };
    document.getElementById('currentDate').innerText =
      new Date().toLocaleDateString('id-ID', opts);
  }

  // ── Footer ────────────────────────────────────────────────
  const footerTexts = [
    `Rajin-rajinlah beribadah<br>Jangan lupa salat<br>Dan perbanyak zakat<br>Untuk bekal akhirat`,
    `Dalam malam yang kelam, rindu membeku<br>Kesedihan menari di antara bayang-bayang`,
    'Dalam malam yang kelam, langit berurai<br>Rindu membeku dalam angin yang merintih<br>Hati terbelah, diwarnai senyap pilu<br>Kesedihan menari di antara bayang-bayang',
    'Di ujung hari yang hampa, bintang meredup<br>Menyisakan jejak air mata di cakrawala<br>Cinta yang hilang, seperti debu tertiup<br>Menghilang dalam ruang yang tak bertepi',
    'Setiap suara angin, menyimpan cerita<br>Tentang harapan yang melayang jauh<br>Di balik awan, gemericik duka<br>Mengiringi langkah yang penuh ragu',
    'Di tengah tawa, air mata menari lembut<br>Senyum yang tulus, membasahi pipi yang cerah<br>Kebahagiaan mengalir dalam setiap tetes<br>Menjadi pelangi setelah hujan yang reda',
    'Ketika harapan menjadi nyata, dan mimpi terwujud<br>Rasa syukur menjadikan air mata sebagai saksi<br>Bahagia mengalir, seiring waktu yang berharga<br>Menyatukan jiwa dalam pelukan cinta yang abadi',
    'Di ujung langit, matahari terbenam lembut<br>Menyeruput warna, melukis cakrawala malam<br>Angin berbisik lembut di antara pepohonan<br>Menyapu jiwa, menenangkan dengan kasih sayang',
    'Bunga-bunga menari dalam embun pagi<br>Keharuman mereka menggema di udara<br>Setiap kelopak, seolah membawa pesan cinta<br>Mengisi hari dengan keajaiban yang nyata',
    'Seorang gadis cantik jelita<br>Telah melintas di depan mata<br>Membuat diri ini terpana<br>Dan juga mendambakan sosoknya',
    'Wajahnya selalu ada dibenak<br>Membuat tidurku jadi tak nyenyak<br>Apakah ini adalah cinta<br>Atau sekadar terkagum saja',
    'Cinta yang ada di ini dada<br>Kian merekah bagai sang bunga<br>Yang telah merekahkan kelopaknya<br>Yang punya warna indah di mata',
    'Kalau mencinta jangan memaksa<br>Supaya tidak saling menyiksa<br>Mencintalah dengan seikhlas rasa<br>Supaya tidak saling menyiksa',
    'Jangan engkau buta dalam mencinta<br>Agar kau tidak membabi buta<br>Dalam mencintai sosoknya<br>Dalam mencemburi sosoknya',
    'Jikalau dia memang jodohnya<br>Pastilah nanti akan berjumpa<br>Jikalau memang bukan jodohnya<br>Marilah coba ikhlaskan saja',
    'Wahai kau kekasih yang tercinta<br>Dimanakah engkau kini berada<br>Daku sangat ingin kita berjumpa<br>Dan bercanda tawa bersama-sama',
    'Akan kupanjatkan sebuah doa<br>Untuk dirinya yang kucinta<br>Semoga dia selalu bahagia<br>Dan berada dalam lindungan-Nya',
    'Aku diam bukan karena tak cinta<br>Aku hanya sedang memendam rasa<br>Yang belum saatnya diungkapkan<br>Yang belum saatnya dicurahkan',
    'Jangan mencintai karena materi<br>Nanti kita akan jadi merugi<br>Jangan pula cinta karena rupa<br>Nanti cinta kita akan mudah sirna',
    'Jika dia memang bukan jodohnya<br>Mari diikhlaskan saja dirinya<br>Moga nanti akan kita mendapat<br>Pengganti yang jauh lebih tepat',
    'Di ujung hari, bintang meredup<br>Cinta yang hilang menghilang dalam ruang tak bertepi'
  ];
  function randomFooter() {
    document.getElementById('footer').innerHTML =
      footerTexts[Math.floor(Math.random() * footerTexts.length)];
  }

  // ── Shio data ──────────────────────────────────────────────
  const shioData = [
    { name:'SHIO KUDA',    emoji:'🐎', angka:["01","13","25","37","49","61","73","85","97"] },
    { name:'SHIO ULAR',    emoji:'🐍', angka:["02","14","26","38","50","62","74","86","98"] },
    { name:'SHIO NAGA',    emoji:'🐉', angka:["03","15","27","39","51","63","75","87","99"] },
    { name:'SHIO KELINCI', emoji:'🐇', angka:["04","16","28","40","52","64","76","88","00"] },
    { name:'SHIO HARIMAU', emoji:'🐅', angka:["05","17","29","41","53","65","77","89"] },
    { name:'SHIO KERBAU',  emoji:'🐂', angka:["06","18","30","42","54","66","78","90"] },
    { name:'SHIO TIKUS',   emoji:'🐀', angka:["07","19","31","43","55","67","79","91"] },
    { name:'SHIO BABI',    emoji:'🐗', angka:["08","20","32","44","56","68","80","92"] },
    { name:'SHIO ANJING',  emoji:'🐕', angka:["09","21","33","45","57","69","81","93"] },
    { name:'SHIO AYAM',    emoji:'🐓', angka:["10","22","34","46","58","70","82","94"] },
    { name:'SHIO MONYET',  emoji:'🐒', angka:["11","23","35","47","59","71","83","95"] },
    { name:'SHIO KAMBING', emoji:'🐐', angka:["12","24","36","48","60","72","84","96"] }
  ];

  let currentShio = null, angkaIndex = 0, intervalId = null;

  function randomShio() {
    const shio = shioData[Math.floor(Math.random() * shioData.length)];
