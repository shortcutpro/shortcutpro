<html lang="id"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SYAIR + Card Shio + Kemenangan + BBFS + BEBAS + Lokasi</title>
<style>
  body {
    font-family: 'Poppins', sans-serif;
    background: #000000;
    margin: 0;
    padding: 15px;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  :root {
    --elegant-gold: #f5c542;
    --gold-glow: #ffd86b;
    --deep-black: #000;
    --dark-gray: #111;
  }

  .main-card {
    background: linear-gradient(180deg, #111, #000);
    background-image: var(--pasaran-bg, none);
    background-repeat: no-repeat;
    background-position: center center;
    background-size: cover;
    border: 3px solid var(--elegant-gold);
    border-radius: 20px;
    box-shadow: 
      0 0 30px rgba(245, 197, 66, 0.6),
      inset 0 0 40px rgba(245, 197, 66, 0.15),
      0 0 60px rgba(245, 197, 66, 0.3),
      0 8px 20px rgba(0, 0, 0, 0.8);
    padding: 25px;
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    color: #ffd86b;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  /* Overlay gelap agar background tidak ganggu konten */
  .main-card-bg-overlay {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at center, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.75) 100%);
    border-radius: 18px;
    pointer-events: none;
    z-index: 0;
  }

  .main-card::before {
    content: '';
    position: absolute;
    top: -2px; left: -2px; right: -2px; bottom: -2px;
    background: linear-gradient(45deg, 
      transparent 0%, rgba(245,197,66,0.1) 25%,
      rgba(245,197,66,0.3) 50%, rgba(245,197,66,0.1) 75%, transparent 100%);
    border-radius: 22px;
    z-index: 1;
    pointer-events: none;
    animation: shimmer 3s infinite linear;
  }

  @keyframes shimmer {
    0% { background-position: -150px 0; }
    100% { background-position: 150px 0; }
  }

  .main-card::after {
    content: '';
    position: absolute;
    top: 8px; left: 8px; right: 8px; bottom: 8px;
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: 16px;
    pointer-events: none;
    z-index: 1;
  }

  .main-card > * { position: relative; z-index: 2; }

  .syair-header,
  .compass-card,
  .extra-cards .card,
  .footer-card,
  .locations-card,
  .shio-card {
    background: linear-gradient(180deg, #1a1a1a 0%, #000 100%);
    border: 2px solid var(--elegant-gold);
    border-radius: 15px;
    box-shadow: 
      inset 0 0 15px rgba(245,197,66,0.15),
      0 0 15px rgba(245,197,66,0.4),
      0 4px 10px rgba(0,0,0,0.6);
    color: var(--gold-glow);
    position: relative;
    overflow: hidden;
  }

  .syair-header {
    padding: 15px;
    text-align: center;
  }

  .syair-header h2 {
    margin: 0;
    font-size: 22px;
    text-shadow: 0 0 10px var(--elegant-gold), 0 0 20px rgba(245,197,66,0.4), 1px 1px 3px rgba(0,0,0,0.7);
    color: var(--elegant-gold);
    letter-spacing: 0.5px;
    font-weight: 700;
  }

  .hokbentoto-logo-img {
    display: block;
    margin: 10px auto;
    max-height: 60px;
    max-width: 260px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 10px rgba(245,197,66,0.7)) drop-shadow(0 0 20px rgba(245,197,66,0.4));
  }

  .syair-header .date-text {
    font-size: 16px;
    text-shadow: 0 0 6px var(--elegant-gold), 0 0 12px rgba(245,197,66,0.4);
    margin-top: 8px;
    color: #ffeebb;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .syair-header .syair-subtitle {
    margin-top: 8px;
    font-size: 16px;
    font-weight: bold;
    text-shadow: 0 0 10px var(--elegant-gold), 1px 1px 3px rgba(0,0,0,0.7);
    color: #ffdd88;
    letter-spacing: 0.5px;
  }

  .middle-section { 
    display: flex; 
    flex-direction: column;
    gap: 20px; 
  }

  .compass-row {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  .compass-card {
    position: relative;
    width: 180px;
    height: 180px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .compass-card img {
    width: 80%;
    height: 80%;
    border-radius: 12px;
    border: 1px solid var(--elegant-gold);
    box-shadow: 0 0 12px rgba(245,197,66,0.3);
  }

  .random-number {
    position: absolute;
    color: var(--elegant-gold);
    font-size: 20px;
    font-weight: bold;
    text-shadow: 0 0 10px var(--elegant-gold), 0 0 18px rgba(245,197,66,0.5), 1px 1px 3px rgba(0,0,0,0.8);
    background: rgba(102,85,0,0.7);
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--elegant-gold);
  }

  .top    { top: 8px;    left: 50%; transform: translateX(-50%); }
  .bottom { bottom: 8px; left: 50%; transform: translateX(-50%); }
  .left   { left: 8px;   top: 50%;  transform: translateY(-50%); }
  .right  { right: 8px;  top: 50%;  transform: translateY(-50%); }

  .shio-row {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }

  .shio-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12px;
    gap: 8px;
    width: 180px;
    height: 240px;
  }

  .shio-emoji-frame {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 2px solid var(--elegant-gold);
    box-shadow: 
      0 0 20px rgba(245,197,66,0.5),
      0 0 40px rgba(245,197,66,0.2),
      inset 0 0 20px rgba(245,197,66,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: radial-gradient(circle at 30% 30%, #2a2000, #0a0800);
    animation: shioGlow 2s ease-in-out infinite alternate;
    flex-shrink: 0;
  }

  @keyframes shioGlow {
    0%  { box-shadow: 0 0 15px rgba(245,197,66,0.4), 0 0 30px rgba(245,197,66,0.15), inset 0 0 15px rgba(245,197,66,0.08); }
    100%{ box-shadow: 0 0 25px rgba(245,197,66,0.7), 0 0 50px rgba(245,197,66,0.3), inset 0 0 25px rgba(245,197,66,0.15); }
  }

  .shio-emoji-frame::before {
    content: '';
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    border: 1px solid rgba(245,197,66,0.3);
  }

  .shio-emoji-frame::after {
    content: '✦';
    position: absolute;
    top: 6px;
    right: 8px;
    font-size: 10px;
    color: rgba(245,197,66,0.5);
  }

  .shio-emoji {
    font-size: 72px;
    line-height: 1;
    filter: drop-shadow(0 0 8px rgba(245,197,66,0.6)) drop-shadow(0 2px 4px rgba(0,0,0,0.9));
    position: relative;
    z-index: 1;
    animation: shioFloat 3s ease-in-out infinite;
  }

  @keyframes shioFloat {
    0%, 100% { transform: translateY(0px) scale(1); }
    50%       { transform: translateY(-4px) scale(1.05); }
  }

  .shio-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .shio-info h2 {
    margin: 4px 0 0 0;
    font-size: 14px;
    text-shadow: 0 0 10px var(--elegant-gold), 1px 1px 3px rgba(0,0,0,0.7);
    color: var(--elegant-gold);
    font-weight: 700;
    letter-spacing: 0.5px;
    text-align: center;
  }

  .shio-angka-tengah {
    font-size: 26px;
    font-weight: bold;
    color: var(--elegant-gold);
    text-shadow: 0 0 15px var(--elegant-gold), 0 0 25px rgba(245,197,66,0.5), 2px 2px 4px rgba(0,0,0,0.9);
    background: linear-gradient(145deg, #1a1a1a, #000);
    padding: 8px 18px;
    border-radius: 12px;
    border: 1px solid var(--elegant-gold);
    box-shadow: inset 0 0 15px rgba(245,197,66,0.2), 0 0 20px rgba(245,197,66,0.3);
    margin: 4px 0;
    letter-spacing: 2px;
    display: inline-block;
    text-align: center;
    min-width: 70px;
  }

  .extra-cards { display: flex; gap: 10px; }

  .extra-cards .card {
    text-align: center;
    padding: 12px 15px;
    min-width: 80px;
  }

  .extra-cards h3 {
    margin: 0;
    font-size: 16px;
    text-shadow: 0 0 8px var(--elegant-gold), 1px 1px 3px rgba(0,0,0,0.7);
    color: var(--elegant-gold);
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .extra-cards p {
    margin: 6px 0 0 0;
    font-size: 14px;
    font-weight: bold;
    color: #ffdd88;
    text-shadow: 0 0 8px rgba(245,197,66,0.5);
  }

  .footer-card {
    padding: 15px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: #ffdd88;
    line-height: 1.4;
  }

  .link-HOKBENTOTO-outside {
    margin-top: 15px;
    font-size: 18px;
    font-weight: bold;
    color: var(--elegant-gold);
    text-align: center;
    text-shadow: 0 0 10px var(--elegant-gold), 0 0 20px var(--elegant-gold), 1px 1px 3px rgba(0,0,0,0.7);
    position: relative;
    z-index: 2;
    letter-spacing: 1px;
    padding: 10px;
    background: linear-gradient(45deg, rgba(245,197,66,0.2), rgba(102,85,0,0.2));
    border-radius: 8px;
    border: 1px solid var(--elegant-gold);
  }

  .locations-card {
    margin-top: 15px;
    padding: 15px;
    text-align: center;
  }

  .locations-card h3 {
    margin: 0 0 10px 0;
    font-size: 16px;
    text-shadow: 0 0 8px var(--elegant-gold), 1px 1px 3px rgba(0,0,0,0.7);
    color: var(--elegant-gold);
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .pasaran-logo-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, rgba(245,197,66,0.15), rgba(102,85,0,0.15));
    padding: 10px 20px;
    border-radius: 10px;
    border: 1px solid var(--elegant-gold);
    box-shadow: 0 0 10px rgba(245,197,66,0.5), 0 4px 6px rgba(0,0,0,0.4), inset 0 0 6px rgba(245,197,66,0.1);
    margin: 4px;
    min-width: 120px;
    min-height: 50px;
  }

  .pasaran-logo-wrap img {
    max-height: 42px;
    max-width: 170px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 5px rgba(245,197,66,0.4)) brightness(1.1);
  }

  .pasaran-name-fallback {
    font-weight: bold;
    font-size: 14px;
    color: var(--gold-glow);
    letter-spacing: 0.5px;
    text-shadow: 0 0 8px rgba(245,197,66,0.5);
    display: none;
  }

  /* Tablet */
  @media (min-width: 768px) {
    .main-card { padding: 30px; max-width: 700px; }
    .middle-section { flex-direction: row; justify-content: space-between; }
    .compass-row { flex-direction: column; align-items: center; width: 48%; }
    .shio-row { width: 48%; justify-content: center; }
    .syair-header h2 { font-size: 24px; }
    .extra-cards { flex-direction: row; justify-content: center; width: 100%; }
    .hokbentoto-logo-img { max-height: 65px; max-width: 280px; }
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .main-card { max-width: 800px; padding: 35px; }
    .compass-card { width: 200px; height: 200px; }
    .shio-card { width: 200px; height: 260px; }
    .shio-emoji-frame { width: 155px; height: 155px; }
    .shio-emoji { font-size: 82px; }
    .random-number { font-size: 22px; width: 40px; height: 40px; }
    .extra-cards .card { padding: 15px 20px; }
    .extra-cards h3 { font-size: 18px; }
    .extra-cards p { font-size: 16px; }
  }

  /* Mobile kecil */
  @media (max-width: 480px) {
    body { padding: 10px; }
    .main-card { padding: 15px; border-radius: 15px; }
    .compass-card { width: 150px; height: 150px; }
    .shio-card { width: 155px; height: 210px; }
    .shio-emoji-frame { width: 115px; height: 115px; }
    .shio-emoji { font-size: 58px; }
    .shio-angka-tengah { font-size: 22px; min-width: 60px; padding: 6px 12px; }
    .random-number { font-size: 16px; width: 28px; height: 28px; }
    .extra-cards { flex-direction: column; align-items: center; }
    .extra-cards .card { width: 100%; max-width: 180px; }
    .hokbentoto-logo-img { max-height: 48px; max-width: 190px; }
    .syair-header h2 { font-size: 20px; }
    .link-HOKBENTOTO-outside { font-size: 16px; padding: 8px; }
    .pasaran-logo-wrap img { max-height: 32px; max-width: 120px; }
    .pasaran-logo-wrap { min-width: 90px; min-height: 42px; padding: 8px 12px; }
  }
</style>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="main-card" id="mainCard">
  <div class="main-card-bg-overlay"></div>

  <!-- HEADER -->
  <div class="syair-header">
    <h2>SYAIR TOGEL</h2>
    <img
      class="hokbentoto-logo-img"
      src="https://cdn.areabermain.club/assets/cdn/az6/2026/02/04/20260204/b320864d719e41630e6662f49dee7ebf/logo-mobile.png"
