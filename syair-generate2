  function renderRandomLocation() {
    const container = document.getElementById('locationsList');
    container.innerHTML = '';
    const item = locations[Math.floor(Math.random() * locations.length)];

    // Background main-card pakai icon (png-res)
    const mainCard = document.getElementById('mainCard');
    mainCard.style.setProperty('--pasaran-bg', `url('${item.icon}')`);

    const wrap = document.createElement('div');
    wrap.className = 'pasaran-logo-wrap';

    const img = document.createElement('img');
    img.src = item.logo;
    img.alt = item.name;

    const fallback = document.createElement('span');
    fallback.className = 'pasaran-name-fallback';
    fallback.innerText = item.name;

    img.onerror = function() {
      this.style.display = 'none';
      fallback.style.display = 'inline';
    };

    wrap.appendChild(img);
    wrap.appendChild(fallback);
    container.appendChild(wrap);
  }

